# App
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/recharged

# Stripe (Recharged platform account)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CLIENT_ID=ca_...          # For Connect OAuth
STRIPE_WEBHOOK_SECRET=whsec_...         # stripe listen --forward-to /api/stripe/webhook
STRIPE_BILLING_WEBHOOK_SECRET=whsec_... # stripe listen --forward-to /api/billing/webhook

# Recharged plan price IDs – MRR-based tiers (run `npm run stripe:setup` to create)
STRIPE_PRICE_MRR_5K=price_...    # $0–$5k MRR    → $1/mo
STRIPE_PRICE_MRR_20K=price_...   # $5k–$20k MRR  → $47/mo
STRIPE_PRICE_MRR_50K=price_...   # $20k–$50k MRR → $97/mo
STRIPE_PRICE_MRR_150K=price_...  # $50k–$150k MRR→ $297/mo
STRIPE_PRICE_MRR_250K=price_...  # $150k–$250k MRR→$497/mo
STRIPE_PRICE_MRR_PLUS=price_...  # $250k+ MRR    → $997/mo

# Google AI (Gemini)
GOOGLE_AI_API_KEY=AIza...

# Resend (email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@recharged.app
